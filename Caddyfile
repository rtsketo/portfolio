rtsketo.eu {
	root * /srv/public
	encode zstd gzip
	file_server

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	# Long-lived cache for fingerprint-stable static assets
	@static {
		path *.css *.js *.webp *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2
	}
	header @static Cache-Control "public, max-age=2592000, immutable"

	# Manifest and robots/sitemap: cache briefly
	@meta {
		path /site.webmanifest /robots.txt /sitemap.xml
	}
	header @meta Cache-Control "public, max-age=86400"

	# HTML: always revalidate
	@html {
		path / *.html
	}
	header @html Cache-Control "public, max-age=0, must-revalidate"
}
